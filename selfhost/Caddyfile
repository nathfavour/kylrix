# ─────────────────────────────────────────────────────────────────────────────
# Kylrix — Caddyfile
# Automatic HTTPS via Let's Encrypt / ZeroSSL
# Domain is injected via {$DOMAIN} environment variable
# ─────────────────────────────────────────────────────────────────────────────

{$DOMAIN:localhost} {
	# ── Reverse proxy to the Next.js app ──
	reverse_proxy kylrix:3000 {
		# Health checking — Caddy will stop sending traffic to unhealthy backends
		health_uri /api/health
		health_interval 30s
		health_timeout 5s

		# Proper headers for Next.js (SSR needs these for correct URL generation)
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}

	# ── Compression ──
	encode gzip zstd

	# ── Security headers ──
	header {
		# Prevent MIME type sniffing
		X-Content-Type-Options "nosniff"
		# Clickjacking protection
		X-Frame-Options "SAMEORIGIN"
		# XSS protection (legacy browsers)
		X-XSS-Protection "1; mode=block"
		# Referrer policy
		Referrer-Policy "strict-origin-when-cross-origin"
		# Remove server identification
		-Server
	}

	# ── Logging ──
	log {
		output stdout
		format console
		level INFO
	}
}
