# ─────────────────────────────────────────────────────────────────────────────
# Kylrix — Caddyfile
# Automatic HTTPS via Let's Encrypt / ZeroSSL
#
# Environment variables (set in .env):
#   DOMAIN          — Main app domain (e.g. kylrix.example.com)
#   APPWRITE_DOMAIN — Appwrite API domain (e.g. api.example.com)
# ─────────────────────────────────────────────────────────────────────────────

# ── Main Kylrix App ─────────────────────────────────────────────────────────
{$DOMAIN:localhost} {
	# Reverse proxy to the Next.js standalone server
	reverse_proxy kylrix:3000 {
		# Proper headers for SSR URL generation and auth cookies
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}

	# Compression
	encode gzip zstd

	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		-Server
	}

	log {
		output stdout
		format console
		level INFO
	}
}

# ── Appwrite API (bundled mode only) ────────────────────────────────────────
# Routes Appwrite traffic including WebSocket realtime connections.
# If using external Appwrite, remove or comment this block.
{$APPWRITE_DOMAIN:appwrite.localhost} {
	reverse_proxy appwrite:80 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}

	encode gzip zstd

	log {
		output stdout
		format console
		level INFO
	}
}
