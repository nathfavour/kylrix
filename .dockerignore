# ─────────────────────────────────────────────────────────────────────────────
# .dockerignore — Keep Docker build context small and secure
# ─────────────────────────────────────────────────────────────────────────────

# Dependencies (re-installed inside container)
node_modules
.pnpm-store

# Build artifacts (rebuilt inside container)
.next
out

# Source control
.git
.gitignore

# IDE / editor
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Environment (secrets — NEVER bake into images)
.env
.env.*
!.env.example

# Docker infra (not needed inside the image)
Dockerfile
docker-compose*.yml
Makefile
selfhost/

# Documentation
README.md
CHANGELOG.md
LICENSE
docs/

# Tests
__tests__
*.test.*
*.spec.*
coverage/
jest.config.*
vitest.config.*

# Agents / AI config
.agents/
.gemini/
AGENTS.md
